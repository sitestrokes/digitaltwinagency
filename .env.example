# ============================================================
# TwinProfit HQ — Environment Configuration Template
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in all values marked with <angle brackets>
# 3. NEVER commit .env to version control
# ============================================================

CI_ENVIRONMENT = production

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
app.baseURL   = 'https://<your-domain.com>/'
app.indexPage = ''

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
database.default.hostname = 127.0.0.1
database.default.database = digitaltwinagency
database.default.username = <db_username>
database.default.password = <db_password>
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306

# ------------------------------------------------------------
# Encryption key (AES-256)
# Used to encrypt/decrypt user OpenAI API keys stored in DB.
# IMPORTANT: Generate a NEW unique key for each environment.
# Run this command to generate one:
#   php -r "echo 'hex2bin(\'' . bin2hex(random_bytes(32)) . '\')' . PHP_EOL;"
# Then paste the full hex2bin('...') value below.
# WARNING: If you change this key, all existing encrypted API
# keys in the database will become unreadable.
# ------------------------------------------------------------
encryption.key    = hex2bin('<64_hex_characters_here>')
encryption.driver = OpenSSL

# ------------------------------------------------------------
# Session
# ------------------------------------------------------------
session.driver             = 'CodeIgniter\Session\Handlers\FileHandler'
session.cookieName         = 'dta_session'
session.expiration         = 7200
session.savePath           = '/var/www/<your-project-path>/writable/session'
session.matchIP            = false
session.timeToUpdate       = 300
session.regenerateDestroy  = false
